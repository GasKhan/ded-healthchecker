# Telegram Bot API token (получить у @BotFather)
BOT_TOKEN=

# Telegram user_id владельца — единственный, кто может управлять
# списком получателей через /subscribe, /unsubscribe, /recipients.
# Узнать свой id: написать @userinfobot.
OWNER_ID=

# Путь к services.yml (опционально, по умолчанию ./services.yml)
# SERVICES_CONFIG_PATH=services.yml

# Путь к recipients.json (опционально, по умолчанию ./recipients.json)
# RECIPIENTS_PATH=recipients.json
