# Telegram Bot API token (получить у @BotFather)
BOT_TOKEN=

# Telegram chat_id чата-владельца. Команды управления (/subscribe,
# /unsubscribe, /recipients) принимаются только из этого чата.
# Варианты:
#   - Личка владельца: положительный user_id (узнать у @userinfobot).
#   - Группа админов: отрицательный chat_id вида -1001234567890
#     (узнать, добавив @RawDataBot в группу).
# В группе любой её участник сможет управлять подписками.
ADMIN_CHAT_ID=

# Путь к services.yml (опционально, по умолчанию ./services.yml)
# SERVICES_CONFIG_PATH=services.yml

# Путь к recipients.json (опционально, по умолчанию ./recipients.json)
# RECIPIENTS_PATH=recipients.json
